# Required auth configuration. Do not use demo values in production.
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_USERNAME=replace-admin-username
ADMIN_PASSWORD_HASH=replace-with-pbkdf2-hash
MANAGER_USERNAME=replace-manager-username
MANAGER_PASSWORD_HASH=replace-with-pbkdf2-hash

# SQLite file used by the Prisma better-sqlite3 adapter.
DATABASE_FILE=dev.db

# Optional Telegram lead notification integration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Public site URL used by metadata/sitemap/integrations.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
